{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "ai.dinglebear/unifi-rmcp",
  "title": "UniFi RMCP",
  "description": "Rust MCP server and CLI for UniFi Network controller operations.",
  "version": "0.2.5",
  "websiteUrl": "https://github.com/jmagar/runifi",
  "repository": {
    "url": "https://github.com/jmagar/runifi",
    "source": "github",
    "id": "1238227294"
  },
  "icons": [
    {
      "src": "https://avatars.githubusercontent.com/u/38927646?v=4",
      "mimeType": "image/png",
      "sizes": [
        "460x460"
      ],
      "theme": "dark"
    }
  ],
  "packages": [
    {
      "registryType": "npm",
      "registryBaseUrl": "https://registry.npmjs.org",
      "identifier": "unifi-rmcp",
      "version": "0.2.5",
      "runtimeHint": "npx",
      "packageArguments": [
        {
          "type": "positional",
          "value": "mcp",
          "description": "Run UniFi RMCP over stdio.",
          "format": "string",
          "isRequired": true,
          "isSecret": false,
          "isRepeated": false
        }
      ],
      "environmentVariables": [
        {
          "name": "UNIFI_URL",
          "description": "UniFi Network controller base URL.",
          "format": "string",
          "isRequired": true,
          "isSecret": false,
          "placeholder": "https://unifi.example.com"
        },
        {
          "name": "UNIFI_API_KEY",
          "description": "UniFi API key.",
          "format": "string",
          "isRequired": true,
          "isSecret": true
        },
        {
          "name": "UNIFI_RMCP_VERSION",
          "description": "Optional GitHub release tag override for the downloaded UniFi RMCP binary.",
          "format": "string",
          "isRequired": false,
          "isSecret": false,
          "placeholder": "v0.2.3"
        },
        {
          "name": "UNIFI_RMCP_REPO",
          "description": "Optional GitHub owner/repo override for release asset downloads.",
          "format": "string",
          "isRequired": false,
          "isSecret": false,
          "default": "jmagar/runifi",
          "placeholder": "jmagar/runifi"
        },
        {
          "name": "UNIFI_RMCP_RELEASE_BASE_URL",
          "description": "Optional release download base URL override.",
          "format": "string",
          "isRequired": false,
          "isSecret": false
        },
        {
          "name": "RUST_LOG",
          "description": "Tracing filter for UniFi RMCP logs.",
          "format": "string",
          "isRequired": false,
          "isSecret": false,
          "default": "info",
          "placeholder": "info"
        }
      ],
      "transport": {
        "type": "stdio"
      }
    }
  ],
  "_meta": {
    "io.modelcontextprotocol.registry/publisher-provided": {
      "namespace": "ai.dinglebear",
      "dnsDomain": "dinglebear.ai",
      "distribution": {
        "npm": "unifi-rmcp@0.2.4",
        "nodePackage": "unifi-rmcp"
      },
      "buildInfo": {
        "version": "0.2.4",
        "repository": "https://github.com/jmagar/runifi"
      }
    }
  }
}
