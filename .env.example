# ── Secrets & URLs (stay in .env, never in config.toml) ──────────────────────

# Base URL of your UniFi controller (required)
UNIFI_URL=https://unifi.local

# API key for X-API-KEY header authentication (required)
# Generate in: UniFi OS → Settings → Admins & Users → API Keys
UNIFI_API_KEY=replace-me

# Official Network Integration API site UUID, used by official_* live tests.
# Internal legacy-style actions continue to use UNIFI_SITE, usually "default".
# UNIFI_SITE_ID=

# Static bearer token for MCP auth (generate with: openssl rand -hex 32)
UNIFI_MCP_TOKEN=replace-me

# ── OAuth secrets (only needed when UNIFI_MCP_AUTH_MODE=oauth) ────────────────
# UNIFI_MCP_GOOGLE_CLIENT_ID=
# UNIFI_MCP_GOOGLE_CLIENT_SECRET=

# ── Security overrides ────────────────────────────────────────────────────────
# Set UNIFI_NOAUTH=true ONLY when an upstream reverse proxy/gateway handles auth.
# Without this, the server refuses to bind to non-loopback without UNIFI_MCP_TOKEN set.
# UNIFI_NOAUTH=true

# ── All other config lives in config.toml ─────────────────────────────────────
# site, skip_tls_verify, legacy, mcp.host, mcp.port, mcp.server_name,
# auth.mode, auth.admin_email, auth.allowed_emails, etc.
# Override any config.toml value here as an env var:
#
# UNIFI_SITE=default
# UNIFI_SKIP_TLS_VERIFY=true
# UNIFI_LEGACY=false
# UNIFI_MCP_HOST=0.0.0.0
# UNIFI_MCP_PORT=40030
# UNIFI_MCP_NO_AUTH=false
# UNIFI_MCP_PUBLIC_URL=https://unifi-rmcp.example.com
# UNIFI_MCP_AUTH_MODE=bearer

# ── Logging ───────────────────────────────────────────────────────────────────
# RUST_LOG=info
